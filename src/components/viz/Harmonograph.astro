---
/**
 * Harmonograph — 第 1 层「animated-SVG」（零 JS）。
 *
 * 主题：Lissajous 图形 —— 两个垂直方向的简谐振动 x=sin(aθ+δ)、y=sin(bθ) 合成的
 * 封闭曲线，频率比 a:b 决定花样。路径在**构建期**算好（frontmatter 里跑一次），
 * 运行时零 JS；用 CSS `stroke-dashoffset` 让一段高光沿曲线匀速「巡游」，无限平滑循环。
 *
 * 主题契约：三条曲线各用一种分类色 `--color-cat-{1,3,5}`（跨主题稳定保持身份），
 * 底图低透明、巡游高光亮；`prefers-reduced-motion: reduce` 时停掉巡游、只留静态全图。
 */
interface Props {
  size?: number;
  caption?: string;
}
const { size = 320, caption } = Astro.props;
const uid = crypto.randomUUID();

const W = 320;
const H = 220;
const cx = W / 2;
const cy = H / 2;
const Rx = 140;
const Ry = 92;
const STEPS = 480;

// 构建期生成 Lissajous 路径串：x=cx+Rx·sin(aθ+δ)，y=cy+Ry·sin(bθ)，θ∈[0,2π]。
function lissajous(a: number, b: number, delta: number) {
  const pts: string[] = [];
  for (let i = 0; i <= STEPS; i += 1) {
    const t = (i / STEPS) * Math.PI * 2;
    const x = cx + Rx * Math.sin(a * t + delta);
    const y = cy + Ry * Math.sin(b * t);
    pts.push(`${x.toFixed(2)},${y.toFixed(2)}`);
  }
  return `M${pts.join(" L")}Z`;
}

const curves = [
  { d: lissajous(3, 2, Math.PI / 2), color: "--color-cat-1", dur: "7s" },
  { d: lissajous(5, 4, Math.PI / 4), color: "--color-cat-3", dur: "9s" },
  { d: lissajous(4, 5, Math.PI / 3), color: "--color-cat-5", dur: "11s" },
];
---

<figure class="not-prose text-foreground my-8 flex flex-col items-center gap-3">
  <svg
    aria-labelledby={`${uid}-t ${uid}-d`}
    class="h-auto max-w-full"
    height={(size * H) / W}
    role="img"
    viewBox={`0 0 ${W} ${H}`}
    width={size}
    xmlns="http://www.w3.org/2000/svg"
  >
    <title id={`${uid}-t`}>Lissajous 谐波图</title>
    <desc id={`${uid}-d`}
      >三条不同频率比的 Lissajous 封闭曲线，各有一段高光沿线巡游；构建期生成路径、运行时零 JS。</desc
    >
    {
      curves.map((c) => (
        <Fragment>
          <path
            d={c.d}
            fill="none"
            stroke={`var(${c.color})`}
            stroke-width="1.4"
            stroke-opacity="0.16"
          />
          <path
            class="ho-run"
            d={c.d}
            fill="none"
            stroke={`var(${c.color})`}
            stroke-width="2.4"
            stroke-linecap="round"
            pathLength="1"
            style={`--dur:${c.dur}`}
          />
        </Fragment>
      ))
    }
  </svg>
  {caption && <figcaption class="text-sm opacity-70">{caption}</figcaption>}
</figure>

<style>
  /* pathLength="1" 把整条曲线长度归一为 1：一段 14% 的高光 + 86% 的空隙，
     offset 从 1 到 0 让高光沿闭合曲线无缝巡游（14%+86%=100%，循环不跳变）。 */
  .ho-run {
    stroke-dasharray: 0.14 0.86;
  }
  @media (prefers-reduced-motion: no-preference) {
    .ho-run {
      animation: ho-trace var(--dur, 8s) linear infinite;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ho-run {
      display: none;
    }
  }
  @keyframes ho-trace {
    from {
      stroke-dashoffset: 1;
    }
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
